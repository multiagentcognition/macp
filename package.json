{
  "name": "macp",
  "version": "3.0.0",
  "type": "module",
  "description": "Multi-Agent Cognition Protocol — shared SQLite coordination layer for AI agents.",
  "license": "Apache-2.0",
  "main": "./build/src/index.js",
  "types": "./build/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "import": "./build/src/index.js"
    },
    "./schema": {
      "types": "./build/src/schema.d.ts",
      "import": "./build/src/schema.js"
    },
    "./macp.schema.json": "./macp.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "build/src/",
    "macp.schema.json",
    "spec/MACP-Protocol-v1.0.md",
    "docs/TUTORIAL.md",
    "docs/EXTENSIONS.md",
    "docs/SECURITY.md",
    "examples/MACP_COORDINATION.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiagentcognition/macp.git"
  },
  "homepage": "https://macp.dev",
  "keywords": [
    "agents",
    "ai",
    "coordination",
    "protocol",
    "sqlite"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate": "npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
